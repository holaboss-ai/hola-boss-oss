{
  "name": "docs",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test index.test.mjs",
    "build": "vitepress build docs",
    "dev": "vitepress dev docs --host 0.0.0.0 --port 4173",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 4173",
    "preview": "vitepress preview docs --host 0.0.0.0 --port 4173",
    "docs:preview": "vitepress preview docs --host 0.0.0.0 --port 4173",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "deploy:production": "npm run build && wrangler deploy --env production"
  },
  "devDependencies": {
    "vitepress": "^1",
    "vitepress-mermaid-renderer": "^1",
    "wrangler": "^4.80.0"
  }
}
